"use client";
import { useState, useCallback } from 'react';
import type { CSSProperties } from 'react';
import { useDropzone } from 'react-dropzone';
import JSZip from 'jszip';
import { saveAs } from 'file-saver';
import {
  Upload,
  Download,
  Archive,
  Trash2,
  Loader2,
  CheckCircle2,
  XCircle,
  FileImage,
  Target,
  Settings,
  Maximize2,
} from 'lucide-react';
import BackButton from '../components/BackButton';
import OtherTools from '../components/OtherTools';
import { formatBytes } from '../utils/format';
import '../App.css';

const MAX_FILES = 10;
// Max 50MP or 50MB per file — Lanczos in browser is very memory-efficient
const MAX_PIXELS = 50_000_000;
const MAX_FILE_BYTES = 50 * 1024 * 1024;

interface UpscaledFile {
  id: string;
  name: string;
  originalFile: File;
  originalSize: number;
  originalWidth: number;
  originalHeight: number;
  targetWidth: number;
  targetHeight: number;
  status: 'pending' | 'processing' | 'done' | 'error';
  blob: Blob | null;
  upscaledSize: number | null;
  progress: number;
  error?: string;
}

const SCALE_OPTIONS = [
  { label: '2x Upscale', value: 2 },
  { label: '4x Upscale', value: 4 },
];

const FORMAT_OPTIONS = [
  { label: 'Keep Original', value: 'original' },
  { label: 'PNG (Lossless)', value: 'png' },
  { label: 'JPEG', value: 'jpeg' },
  { label: 'WebP', value: 'webp' },
];

function statusColor(status: UpscaledFile['status']): string {
  switch (status) {
    case 'done':       return 'var(--success)';
    case 'error':      return 'var(--error)';
    case 'processing': return 'var(--accent)';
    default:           return 'var(--text-muted)';
  }
}

export default function UpscaleImage() {
  const [files, setFiles] = useState<UpscaledFile[]>([]);
  const [scaleFactor, setScaleFactor] = useState<number>(2);
  const [outputFormat, setOutputFormat] = useState<string>('original');
  const [processing, setProcessing] = useState(false);
  const [zipping, setZipping] = useState(false);
  const [trimmed, setTrimmed] = useState(false);
  const [resolutionError, setResolutionError] = useState(false);

  const isLocked = files.length >= MAX_FILES;

  const clearAll = () => {
    setFiles([]);
    setTrimmed(false);
    setResolutionError(false);
  };

  const getImageDimensions = (file: File): Promise<{ width: number; height: number }> => {
    return new Promise((resolve, reject) => {
      const img = new Image();
      const src = URL.createObjectURL(file);
      img.src = src;
      img.onload = () => { resolve({ width: img.naturalWidth, height: img.naturalHeight }); URL.revokeObjectURL(src); };
      img.onerror = (err) => { reject(err); URL.revokeObjectURL(src); };
    });
  };

  const onDrop = useCallback(
    async (accepted: File[]) => {
      if (!accepted.length || isLocked) return;
      setResolutionError(false);

      const slotsLeft = MAX_FILES - files.length;
      const sliced = accepted.slice(0, slotsLeft);
      setTrimmed(accepted.length > slotsLeft);

      const newFiles: UpscaledFile[] = [];
      let skipped = false;

      for (const file of sliced) {
        if (file.size > MAX_FILE_BYTES) { skipped = true; continue; }
        try {
          const dims = await getImageDimensions(file);
          if (dims.width * dims.height > MAX_PIXELS) { skipped = true; continue; }
          newFiles.push({
            id: crypto.randomUUID(),
            name: file.name,
            originalFile: file,
            originalSize: file.size,
            originalWidth: dims.width,
            originalHeight: dims.height,
            targetWidth: dims.width * scaleFactor,
            targetHeight: dims.height * scaleFactor,
            status: 'pending',
            blob: null,
            upscaledSize: null,
            progress: 0,
          });
        } catch {
          skipped = true;
        }
      }

      if (skipped) setResolutionError(true);
      if (newFiles.length) setFiles(prev => [...prev, ...newFiles]);
    },
    [files.length, isLocked, scaleFactor]
  );

  const { getRootProps, getInputProps, isDragActive, isDragReject } = useDropzone({
    onDrop,
    disabled: isLocked || processing,
    accept: {
      'image/png': ['.png'],
      'image/jpeg': ['.jpg', '.jpeg'],
      'image/webp': ['.webp'],
      'image/avif': ['.avif'],
    },
    multiple: true,
  });

  const runUpscale = async () => {
    if (processing) return;
    setProcessing(true);

    // Lazily import pica client-side only
    const { default: Pica } = await import('pica');
    const picaInstance = Pica();

    const pendingFiles = files.filter(f => f.status === 'pending' || f.status === 'error');

    for (const file of pendingFiles) {
      setFiles(prev => prev.map(f => f.id === file.id ? { ...f, status: 'processing', progress: 10 } : f));

      try {
        // 1. Load original image onto a canvas
        const img = new Image();
        const srcUrl = URL.createObjectURL(file.originalFile);
        img.src = srcUrl;
        await new Promise<void>((res, rej) => { img.onload = () => res(); img.onerror = rej; });

        const srcCanvas = document.createElement('canvas');
        srcCanvas.width = img.naturalWidth;
        srcCanvas.height = img.naturalHeight;
        const srcCtx = srcCanvas.getContext('2d');
        if (!srcCtx) throw new Error('Canvas context unavailable');
        srcCtx.drawImage(img, 0, 0);
        URL.revokeObjectURL(srcUrl);

        setFiles(prev => prev.map(f => f.id === file.id ? { ...f, progress: 30 } : f));

        const tw = file.originalWidth * scaleFactor;
        const th = file.originalHeight * scaleFactor;

        // 2. Upscale using Lanczos3 via pica
        const dstCanvas = document.createElement('canvas');
        dstCanvas.width = tw;
        dstCanvas.height = th;

        await picaInstance.resize(srcCanvas, dstCanvas, {
          filter: 'lanczos3',
          unsharpAmount: 80,   // Post-resize sharpening pass
          unsharpRadius: 0.6,
          unsharpThreshold: 2,
        });

        setFiles(prev => prev.map(f => f.id === file.id ? { ...f, progress: 80 } : f));

        // 3. Determine output MIME type
        const origExt = file.name.split('.').pop()?.toLowerCase() ?? 'png';
        let mimeType = 'image/png';
        if (outputFormat === 'jpeg') mimeType = 'image/jpeg';
        else if (outputFormat === 'webp') mimeType = 'image/webp';
        else if (outputFormat === 'original') {
          if (origExt === 'jpg' || origExt === 'jpeg') mimeType = 'image/jpeg';
          else if (origExt === 'webp') mimeType = 'image/webp';
          else mimeType = 'image/png';
        }

        // 4. Export to blob
        const blob = await picaInstance.toBlob(dstCanvas, mimeType, 0.92);

        setFiles(prev => prev.map(f =>
          f.id === file.id
            ? { ...f, status: 'done', blob, upscaledSize: blob.size, progress: 100, targetWidth: tw, targetHeight: th }
            : f
        ));
      } catch (err) {
        console.error(`Upscale failed for ${file.name}:`, err);
        setFiles(prev => prev.map(f =>
          f.id === file.id
            ? { ...f, status: 'error', error: (err as Error).message || 'Upscale failed' }
            : f
        ));
      }
    }

    setProcessing(false);
  };

  const downloadOne = (file: UpscaledFile) => {
    if (!file.blob) return;
    const lastDot = file.name.lastIndexOf('.');
    const base = lastDot !== -1 ? file.name.slice(0, lastDot) : file.name;
    const origExt = file.name.split('.').pop()?.toLowerCase() ?? 'png';
    const ext = outputFormat === 'original' ? origExt : outputFormat;
    saveAs(file.blob, `${base}_${scaleFactor}x.${ext}`);
  };

  const downloadAll = async () => {
    const done = files.filter(f => f.status === 'done' && f.blob);
    if (!done.length) return;
    setZipping(true);
    try {
      const zip = new JSZip();
      done.forEach(f => {
        const lastDot = f.name.lastIndexOf('.');
        const base = lastDot !== -1 ? f.name.slice(0, lastDot) : f.name;
        const origExt = f.name.split('.').pop()?.toLowerCase() ?? 'png';
        const ext = outputFormat === 'original' ? origExt : outputFormat;
        zip.file(`${base}_${scaleFactor}x.${ext}`, f.blob!);
      });
      const content = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE' });
      saveAs(content, `upscaled-${scaleFactor}x.zip`);
    } finally {
      setZipping(false);
    }
  };

  const total = files.length;
  const doneCount = files.filter(f => f.status === 'done').length;
  const pendingCount = files.filter(f => f.status === 'pending' || f.status === 'error').length;
  const activeProcessing = files.filter(f => f.status === 'processing').length;

  return (
    <main style={s.main}>
      <BackButton />

      <div style={s.toolHero}>
        <h1 style={s.toolTitle}>HD Image Upscale</h1>
        <p style={s.toolDesc}>
          Upscale images to 2x or 4x using <strong>Lanczos3 resampling</strong> — the same high-quality algorithm used by Photoshop and FFmpeg. <strong>100% private</strong> — all processing runs instantly in your browser with zero uploads.
        </p>
      </div>

      {/* ── Configuration */}
      <div style={s.configContainer}>
        <div style={s.configBar}>
          <span style={s.configLabel}><Target size={14} /> Scale Factor:</span>
          <div style={s.optionList}>
            {SCALE_OPTIONS.map(opt => (
              <button
                key={opt.value}
                style={{ ...s.optionBtn, ...(scaleFactor === opt.value ? s.optionBtnActive : {}) }}
                onClick={() => setScaleFactor(opt.value)}
                disabled={processing}
              >
                {opt.label}
              </button>
            ))}
          </div>
        </div>

        <div style={s.configBar}>
          <span style={s.configLabel}><Settings size={14} /> Output Format:</span>
          <select
            value={outputFormat}
            onChange={e => setOutputFormat(e.target.value)}
            style={s.selectInput}
            disabled={processing}
          >
            {FORMAT_OPTIONS.map(opt => (
              <option key={opt.value} value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </div>
      </div>

      {/* ── Drop Zone */}
      <div
        {...getRootProps()}
        style={{
          ...s.dropzone,
          ...(isLocked || processing ? s.dropzoneLocked : {}),
          ...(!isLocked && !processing && isDragActive && !isDragReject ? s.dropzoneActive : {}),
          ...(!isLocked && !processing && isDragReject ? s.dropzoneReject : {}),
        }}
      >
        <input {...getInputProps()} />
        <div style={s.dropContent}>
          <div style={{
            ...s.dropIcon,
            ...(isLocked || processing ? s.dropIconLocked : {}),
            ...(!isLocked && !processing && isDragActive ? s.dropIconActive : {}),
          }}>
            <Upload size={26} color={isLocked || processing ? 'var(--text-dim)' : isDragReject ? 'var(--error)' : 'var(--accent)'} />
          </div>
          <p style={{ ...s.dropTitle, ...(isLocked || processing ? { color: 'var(--text-muted)' } : {}) }}>
            {processing
              ? 'Processing images…'
              : isLocked
                ? 'Clear files below to start a new batch'
                : isDragReject
                  ? 'Only valid images are accepted'
                  : isDragActive
                    ? 'Release to upscale!'
                    : `Drop up to ${MAX_FILES} images here (up to 50MP / 50MB each)`}
          </p>
          <p style={s.dropSub}>
            {!processing && !isLocked && !isDragReject
              ? files.length > 0
                ? `${MAX_FILES - files.length} slot${MAX_FILES - files.length !== 1 ? 's' : ''} remaining · Accepts JPG, PNG, WebP, AVIF`
                : 'Accepts JPG, PNG, WebP, AVIF · Instant Lanczos3 resampling'
              : ''}
          </p>
        </div>
      </div>

      {trimmed && <div style={s.notice}>Some files were skipped — slots are full.</div>}
      {resolutionError && <div style={s.notice}>Some files were skipped — they exceed 50 Megapixels or 50MB.</div>}

      {/* ── Toolbar */}
      {total > 0 && (
        <div style={s.toolbar}>
          <div style={s.toolbarLeft}>
            <span style={s.counter}>{total} / {MAX_FILES}</span>
            {processing ? (
              <span style={s.statBusy}>
                <Loader2 size={14} style={{ animation: 'spin 1s linear infinite' }} />
                Upscaling… ({activeProcessing} active)
              </span>
            ) : doneCount > 0 ? (
              <span style={s.statDone}>
                <CheckCircle2 size={14} />
                {doneCount} of {total} done
              </span>
            ) : (
              <span style={{ fontSize: 13, fontWeight: 500, color: 'var(--text-muted)' }}>
                Ready — {pendingCount} image{pendingCount !== 1 ? 's' : ''} queued
              </span>
            )}
          </div>
          <div style={s.toolbarRight}>
            {pendingCount > 0 && (
              <button style={s.btnPrimary} onClick={runUpscale} disabled={processing}>
                <Maximize2 size={14} />
                Upscale {pendingCount > 1 ? `${pendingCount} Images` : 'Image'}
              </button>
            )}
            {doneCount > 1 && (
              <button style={s.btnDownloadAll} onClick={downloadAll} disabled={zipping}>
                {zipping ? <Loader2 size={14} style={{ animation: 'spin 1s linear infinite' }} /> : <Archive size={14} />}
                {zipping ? 'Zipping…' : 'Download All ZIP'}
              </button>
            )}
            <button style={s.btnGhostDanger} onClick={clearAll} disabled={processing}>
              <Trash2 size={14} />
              Clear All
            </button>
          </div>
        </div>
      )}

      {/* ── File List */}
      {total > 0 && (
        <ul style={s.list}>
          {files.map(file => (
            <li key={file.id} style={s.card}>
              <div style={s.cardLeft}>
                <div style={{ color: statusColor(file.status), flexShrink: 0 }}>
                  <FileImage size={20} />
                </div>
                <div style={s.fileNames}>
                  <span style={s.fileOut} title={file.name}>{file.name}</span>
                  <span style={s.fileIn}>
                    {file.originalWidth}×{file.originalHeight} · {formatBytes(file.originalSize)}
                  </span>
                </div>
              </div>

              <div style={s.cardMid}>
                {file.status === 'pending' && (
                  <div style={s.sizeRow}>
                    <span style={s.sizeOrig}>{file.originalWidth}×{file.originalHeight}</span>
                    <span style={s.sizeArrow}>→</span>
                    <span style={s.sizeNew}>{file.originalWidth * scaleFactor}×{file.originalHeight * scaleFactor}</span>
                    <span style={s.pillMuted}>{scaleFactor}x</span>
                  </div>
                )}

                {file.status === 'processing' && (
                  <div style={s.progressWrap}>
                    <div style={s.progressTrack}>
                      <div style={{ ...s.progressBar, width: `${file.progress}%` }} />
                    </div>
                    <span style={s.progressLabel}>Applying Lanczos3… {file.progress}%</span>
                  </div>
                )}

                {file.status === 'done' && file.upscaledSize !== null && (
                  <div style={s.sizeRow}>
                    <span style={s.sizeOrig}>{file.originalWidth}×{file.originalHeight}</span>
                    <span style={s.sizeArrow}>→</span>
                    <span style={s.sizeNew}>{file.targetWidth}×{file.targetHeight}</span>
                    <span style={s.savingsPill}>{formatBytes(file.upscaledSize)}</span>
                  </div>
                )}

                {file.status === 'error' && (
                  <span style={s.errorRow} title={file.error}>
                    <XCircle size={13} />
                    {file.error || 'Upscale failed'}
                  </span>
                )}
              </div>

              <div style={s.cardRight}>
                {file.status === 'done' && (
                  <button style={s.btnDownload} onClick={() => downloadOne(file)}>
                    <Download size={13} />
                    Download
                  </button>
                )}
                {file.status === 'processing' && (
                  <Loader2 size={17} style={{ animation: 'spin 1s linear infinite', color: 'var(--accent)' }} />
                )}
              </div>
            </li>
          ))}
        </ul>
      )}

      {files.length === 0 && (
        <div style={s.empty}>
          <FileImage size={38} color="var(--text-dim)" />
          <p style={s.emptyText}>No images yet — drop some files above</p>
        </div>
      )}

      <OtherTools currentToolId="upscale" />
    </main>
  );
}

